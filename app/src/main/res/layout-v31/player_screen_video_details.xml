<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:background="@color/white">

    <!-- TITLE -->
    <TextView
        android:id="@+id/textView11"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="10dp"
        android:text="Loading..."
        android:textSize="20sp"
        android:textColor="#0A0A0A"
        android:maxLines="3"
        android:ellipsize="end"
        android:fontFamily="@font/roboto_medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/imageView15"/>

    <ImageView
        android:id="@+id/imageView15"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/baseline_keyboard_arrow_down_24_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- META -->
    <TextView
        android:id="@+id/textView14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#6C6C6C"
        android:fontFamily="@font/roboto_medium"
        app:layout_constraintTop_toBottomOf="@id/textView11"
        app:layout_constraintStart_toStartOf="@id/textView11"/>

    <TextView
        android:id="@+id/textView15"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#068BFF"
        android:layout_marginStart="5dp"
        android:fontFamily="@font/roboto_medium"
        app:layout_constraintTop_toTopOf="@id/textView14"
        app:layout_constraintBottom_toBottomOf="@id/textView14"
        app:layout_constraintStart_toEndOf="@id/textView14"/>

    <TextView
        android:id="@+id/textView17"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#068BFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="@font/roboto_medium"
        app:layout_constraintTop_toBottomOf="@id/textView14"
        app:layout_constraintStart_toStartOf="@id/textView14"/>

    <!-- ACTION SCROLL -->
    <include
        android:id="@+id/actionLayout"
        layout="@layout/five_action_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/textView17"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- DIVIDER -->
    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="15dp"
        android:background="#CECECE"
        app:layout_constraintTop_toBottomOf="@id/actionLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CHANNEL -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageView24"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginTop="15dp"
        android:scaleType="centerCrop"
        app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full"
        app:srcCompat="@drawable/person2"
        app:layout_constraintTop_toBottomOf="@id/view"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textView21"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textSize="18sp"
        android:textColor="#0A0A0A"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginHorizontal="20dp"
        android:fontFamily="@font/roboto_regular"
        app:layout_constraintTop_toTopOf="@id/imageView24"
        app:layout_constraintStart_toEndOf="@id/imageView24"
        app:layout_constraintEnd_toStartOf="@id/textView24"/>

    <TextView
        android:id="@+id/textView23"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textSize="16sp"
        android:textColor="#6C6C6C"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/roboto_regular"
        app:layout_constraintTop_toBottomOf="@id/textView21"
        app:layout_constraintStart_toStartOf="@id/textView21"
        app:layout_constraintEnd_toEndOf="@id/textView21"/>

    <TextView
        android:id="@+id/textView24"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SUBSCRIBE"
        android:textSize="18sp"
        android:textColor="#FF0000"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/textView21"
        app:layout_constraintBottom_toBottomOf="@id/textView23"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- COMMENTS -->
    <View
        android:id="@+id/view2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="15dp"
        android:background="#CECECE"
        app:layout_constraintTop_toBottomOf="@id/textView23"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textView25"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comments"
        android:textColor="#0A0A0A"
        android:layout_marginTop="8dp"
        android:layout_marginStart="5dp"
        android:fontFamily="@font/roboto_regular"
        app:layout_constraintTop_toBottomOf="@id/view2"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textView26"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#6C6C6C"
        android:layout_marginStart="3dp"
        app:layout_constraintTop_toTopOf="@id/textView25"
        app:layout_constraintBottom_toBottomOf="@id/textView25"
        app:layout_constraintStart_toEndOf="@id/textView25"/>

    <ImageView
        android:id="@+id/imageView26"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginEnd="5dp"
        app:srcCompat="@drawable/expand"
        app:layout_constraintTop_toTopOf="@id/textView26"
        app:layout_constraintBottom_toBottomOf="@id/textView26"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>