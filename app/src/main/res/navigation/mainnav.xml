<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainnav"
    app:startDestination="@id/splashScreen">

    <fragment
        android:id="@+id/splashScreen"
        android:name="com.ranjan.expertclient.screens.SplashScreen"
        android:label="SplashScreen"
        tools:layout="@layout/splash_screen">
        <action
            android:id="@+id/action_splashScreen_to_browserScreen"
            app:destination="@id/browserScreen" />
        <action
            android:id="@+id/action_splashScreen_to_bottomNavScreen"
            app:destination="@id/bottomNavScreen" />
        <action
            android:id="@+id/action_splashScreen_to_sitesChooserScreen"
            app:destination="@id/sitesChooserScreen" />
    </fragment>

    <fragment
        android:id="@+id/bottomNavScreen"
        android:name="com.ranjan.expertclient.screens.bottomnavscreens.BottomNavScreen"
        android:label="BottomNavScreen"
        tools:layout="@layout/bottom_nav_screen">
        <action
            android:id="@+id/action_bottomNavScreen_to_searchScreen"
            app:destination="@id/searchScreen" />
        <action
            android:id="@+id/action_bottomNavScreen_to_playerScreen"
            app:destination="@id/playerScreen" />
        <action
            android:id="@+id/action_bottomNavScreen_to_playlistScreen"
            app:destination="@id/playlistScreen" />
        <action
            android:id="@+id/action_bottomNavScreen_to_channelScreen"
            app:destination="@id/channelScreen" />
    </fragment>
    <fragment
        tools:layout="@layout/browser_screen"
        android:id="@+id/browserScreen"
        android:name="com.ranjan.expertclient.screens.browserscreen.BrowserScreen"
        android:label="BrowserScreen" >
        <action
            android:id="@+id/action_browserScreen_to_bottomNavScreen"
            app:destination="@id/bottomNavScreen" />
    </fragment>
    <fragment
        android:id="@+id/searchScreen"
        android:name="com.ranjan.expertclient.screens.ytscreens.searchscreen.SearchScreen"
        android:label="SearchScreen"
        tools:layout="@layout/yt_search_screen">
        <action
            android:id="@+id/action_searchScreen_to_playerScreen"
            app:destination="@id/playerScreen" />
        <action
            android:id="@+id/action_searchScreen_to_playlistScreen"
            app:destination="@id/playlistScreen" />
    </fragment>
    <fragment
        android:id="@+id/playerScreen"
        android:name="com.ranjan.expertclient.screens.playerscreen.PlayerScreen"
        android:label="PlayerScreen"
        tools:layout="@layout/player_screen">
        <action
            android:id="@+id/action_playerScreen_to_channelScreen"
            app:destination="@id/channelScreen" />
        <action
            android:id="@+id/action_playerScreen_to_playlistScreen"
            app:destination="@id/playlistScreen" />
    </fragment>
    <fragment
        android:id="@+id/channelScreen"
        android:name="com.ranjan.expertclient.screens.ytscreens.channelscreen.ChannelScreen"
        android:label="ChannelScreen"
        tools:layout="@layout/channel_screen">
        <action
            android:id="@+id/action_channelScreen_to_playlistScreen"
            app:destination="@id/playlistScreen" />
        <argument
            android:name="id"
            app:argType="string"
            android:defaultValue='"none"' />
        <action
            android:id="@+id/action_channelScreen_to_playerScreen"
            app:destination="@id/playerScreen" />
    </fragment>
    <fragment
        android:id="@+id/playlistScreen"
        android:name="com.ranjan.expertclient.screens.ytscreens.playlistscreen.PlaylistScreen"
        android:label="PlaylistScreen"
        tools:layout="@layout/playlist_screen"/>
    <fragment
        tools:layout="@layout/sites_chooser_screen"
        android:id="@+id/sitesChooserScreen"
        android:name="com.ranjan.expertclient.screens.sitesscreen.SitesChooserScreen"
        android:label="SitesChooserScreen" >
        <action
            android:id="@+id/action_sitesChooserScreen_to_browserScreen"
            app:destination="@id/browserScreen" />
        <action
            android:id="@+id/action_sitesChooserScreen_to_feedsScreen"
            app:destination="@id/feedsScreen" />
    </fragment>
    <fragment
        android:id="@+id/feedsScreen"
        android:name="com.ranjan.expertclient.screens.commanscreens.feeds_screen.FeedsScreen"
        android:label="FeedsScreen"
        tools:layout="@layout/feeds_screen"/>
</navigation>